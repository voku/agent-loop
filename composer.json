{
  "name": "voku/agent-loop",
  "description": "Unified Composer CLI for the governed coding-agent loop: board, session, recall, review, learning, memory review, and verification.",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/voku/agent-loop",
  "support": {
    "issues": "https://github.com/voku/agent-loop/issues",
    "source": "https://github.com/voku/agent-loop"
  },
  "authors": [
    {
      "name": "Lars Moelleken",
      "homepage": "https://github.com/voku"
    }
  ],
  "require": {
    "php": "^8.3",
    "voku/agent-kanban": "0.2.*",
    "voku/agent-learning": "0.8.*",
    "voku/agent-map": "0.1.*",
    "voku/agent-recall-compiler": "^0.6.5",
    "voku/agent-session": "0.2.*"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "voku\\AgentLoop\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "voku\\AgentLoop\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/agent-loop"
  ],
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=512M",
    "ci": [
      "@composer validate --strict",
      "@test",
      "@phpstan"
    ]
  },
  "config": {
    "allow-plugins": false,
    "sort-packages": true
  },
  "suggest": {
    "voku/housekeeping": "Standalone cron runner to auto-run agent-loop maintenance tasks against a target repository."
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.3.x-dev"
    }
  }
}
